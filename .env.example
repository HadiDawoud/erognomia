# Project Configuration
PROJECT_NAME=Ergonomia
DEBUG=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest

# Vector Store Configuration
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Ingestion Configuration
TARGET_SITE_URL=https://immersive-reality-lab.de
MAX_CRAWL_DEPTH=5
MAX_PAGES=800
CRAWL_POLITE_DELAY_SEC=0.35
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Where raw JSON snapshots land (manifest.jsonl + pages/*.json) before embeddings
SCRAPED_SNAPSHOT_DIR=./data/scraped

# Optional: comma-separated extra URLs/sitemaps/pages to ALWAYS seed even if linking/sitemap misses them
EXTRA_SEED_URLS=

# RAG Configuration
RETRIEVAL_K=8
RETRIEVAL_MAX_DISTANCE=0.62
